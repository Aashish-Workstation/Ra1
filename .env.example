# RA1 Environment Variables
# Copy to .env and fill in all values
# Generate secrets with: openssl rand -hex 32

# ── LibreChat ────────────────────────────────────────────────
PORT=3080
# generate: openssl rand -hex 32
JWT_SECRET=
# generate: openssl rand -hex 32
JWT_REFRESH_SECRET=
# generate: openssl rand -hex 32
CREDS_KEY=
# generate: openssl rand -hex 16
CREDS_IV=
# generate: openssl rand -hex 32
MEILI_MASTER_KEY=

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=ra1
POSTGRES_DB=ra1
# generate: openssl rand -hex 16
POSTGRES_PASSWORD=

# ── Valkey ───────────────────────────────────────────────────
# generate: openssl rand -hex 16
VALKEY_PASSWORD=

# ── LiteLLM ─────────────────────────────────────────────────
# format: sk-ra1-XXXX (generate: openssl rand -hex 16)
LITELLM_MASTER_KEY=

# ── Infisical ────────────────────────────────────────────────
# generate: openssl rand -hex 16 (exactly 32 hex chars)
INFISICAL_ENCRYPTION_KEY=
# generate: openssl rand -hex 32
INFISICAL_AUTH_SECRET=
# generate: openssl rand -hex 16
INFISICAL_DB_PASSWORD=
# Fill after Infisical is bootstrapped
INFISICAL_SERVICE_TOKEN=
INFISICAL_SYSTEM_PROJECT_ID=
INFISICAL_PROVIDERS_PROJECT_ID=
# Machine client credentials for SDK auth
INFISICAL_MACHINE_CLIENT_ID=
INFISICAL_MACHINE_CLIENT_SECRET=
INFISICAL_ENVIRONMENT=dev
INFISICAL_URL=http://localhost:8080
INFISICAL_HOST=http://localhost:8080
INFISICAL_PROJECT_ID=

# ── Langfuse ─────────────────────────────────────────────────
# generate: openssl rand -hex 32
LANGFUSE_SALT=

# ── RA1 Core ─────────────────────────────────────────────────
# Generate with: python3 -c "import uuid; print(uuid.uuid4())"
RA1_OWNER_ID=

# Generate with: python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
RA1_VAULT_MASTER_KEY=

# ── MinIO ────────────────────────────────────────────────────
MINIO_ROOT_USER=ra1admin
# generate: openssl rand -hex 16
MINIO_ROOT_PASSWORD=