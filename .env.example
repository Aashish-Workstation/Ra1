# RA1 Environment Variables
# Copy to .env and fill in all values
# Generate secrets with: openssl rand -hex 32

# ── LibreChat ────────────────────────────────────────────────
PORT=3080
# generate: openssl rand -hex 32
JWT_SECRET=
# generate: openssl rand -hex 32
JWT_REFRESH_SECRET=
# generate: openssl rand -hex 32
CREDS_KEY=
# generate: openssl rand -hex 16
CREDS_IV=
# generate: openssl rand -hex 32
MEILI_MASTER_KEY=

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=ra1
POSTGRES_DB=ra1
# generate: openssl rand -hex 16
POSTGRES_PASSWORD=

# ── Valkey ───────────────────────────────────────────────────
# generate: openssl rand -hex 16
VALKEY_PASSWORD=

# ── LiteLLM ─────────────────────────────────────────────────
# format: sk-ra1-XXXX (generate: openssl rand -hex 16)
LITELLM_MASTER_KEY=

# ── Infisical ────────────────────────────────────────────────
# generate: openssl rand -hex 16 (exactly 32 hex chars)
INFISICAL_ENCRYPTION_KEY=
# generate: openssl rand -hex 32
INFISICAL_AUTH_SECRET=
# generate: openssl rand -hex 16
INFISICAL_DB_PASSWORD=
# Fill after Infisical is bootstrapped
INFISICAL_SERVICE_TOKEN=
INFISICAL_SYSTEM_PROJECT_ID=
INFISICAL_PROVIDERS_PROJECT_ID=
INFISICAL_ENVIRONMENT=dev
INFISICAL_URL=http://localhost:8080

# ── Langfuse ─────────────────────────────────────────────────
# generate: openssl rand -hex 32
LANGFUSE_SALT=

# ── MinIO ────────────────────────────────────────────────────
MINIO_ROOT_USER=ra1admin
# generate: openssl rand -hex 16
MINIO_ROOT_PASSWORD=