version: 1.2.1

cache: true

endpoints:
  custom:
    - name: "RA1"
      apiKey: "${LITELLM_MASTER_KEY}"
      baseURL: "http://litellm:4000"
      models:
        default:
          - "gpt-4o"
          - "gpt-4o-mini"
          - "claude-3-5-sonnet"
          - "claude-3-5-haiku"
          - "gemini-2.0-flash"
          - "gemini-1.5-flash"
          - "mistral-large"
          - "groq/llama-3.1-70b"
        fetch: false
      titleConvo: true
      titleModel: "gpt-4o-mini"
      summarize: false
      forcePrompt: false
      modelDisplayLabel: "RA1"
      dropParams:
        - "stop"